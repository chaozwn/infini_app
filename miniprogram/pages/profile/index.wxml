<view class="screen">
  <view class="hero profile-hero">
    <navigation-bar title="我的" back="{{false}}" color="#ffffff" background="transparent"></navigation-bar>
    <view class="hero-body profile-head">
      <image wx:if="{{user.avatar}}" class="avatar" src="{{user.avatar}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-default">
        <image class="avatar-icon" src="/assets/icons/user.svg" />
      </view>
      <view class="info">
        <view class="nick">{{user.nickName || (guest ? '游客用户' : '微信用户')}}</view>
        <view class="phone">{{guest ? '游客模式' : (phoneText || '未绑定手机号')}}</view>
      </view>
      <button
        wx:if="{{guest}}"
        class="bind-btn"
        open-type="getPhoneNumber"
        bind:getphonenumber="onBindPhone"
        loading="{{binding}}"
        disabled="{{binding}}"
      >
        绑定手机号
      </button>
    </view>
  </view>

  <view class="content">
    <view class="card menu">
      <view class="menu-item" bindtap="goHistory">
        <view class="menu-left">
          <image class="menu-icon" src="/assets/icons/history.svg" />
          <text>我的报考记录</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goCreate">
        <view class="menu-left">
          <image class="menu-icon" src="/assets/icons/target.svg" />
          <text>生成新方案</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="footer muted">高考报考选校助手 · AI 建议仅供参考</view>
  </view>
</view>
