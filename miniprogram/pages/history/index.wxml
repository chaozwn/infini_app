<view class="screen">
  <view class="hero history-hero">
    <navigation-bar title="历史记录" back="{{false}}" color="#ffffff" background="transparent"></navigation-bar>
    <view class="hero-body">
      <view class="hero-title">我的报考记录</view>
      <view class="hero-sub">共 {{total}} 条 · 点击查看完整方案</view>
    </view>
  </view>

  <view class="content">
    <view wx:if="{{!loading && list.length === 0}}" class="empty">
      <view class="empty-icon">📋</view>
      <text class="muted">还没有报考记录</text>
      <button class="btn-primary" style="width: 360rpx; margin-top: 36rpx;" bindtap="goCreate">去生成方案</button>
    </view>

    <view
      class="card item"
      wx:for="{{list}}"
      wx:key="recordId"
      data-id="{{item.recordId}}"
      bindtap="openDetail"
    >
      <view class="item-head">
        <text class="item-title">{{item.province || '未填省份'}}{{item.targetSchool ? ' · ' + item.targetSchool : ''}}</text>
        <text class="status {{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="item-meta">
        <text wx:if="{{item.score}}">分数 {{item.score}}</text>
        <text wx:if="{{item.rank}}">　位次 {{item.rank}}</text>
        <text wx:if="{{item.pdfReady}}" class="pdf-flag">PDF</text>
      </view>
      <view class="item-foot">
        <text class="item-time">{{item.createdAtText}}</text>
        <text class="item-arrow">查看 ›</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="muted loading-more">加载中...</view>
    <view wx:if="{{!hasMore && list.length > 0}}" class="muted loading-more">没有更多了</view>
  </view>
</view>
