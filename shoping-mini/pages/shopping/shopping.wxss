.page-title {
  margin-top: 8rpx;
}

.subtitle {
  margin: 12rpx 0 24rpx;
}

.field + .field {
  margin-top: 24rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #dbe3ff;
  margin-bottom: 12rpx;
}

.req {
  color: #5fe6ff;
}

.input {
  background: rgba(8, 14, 30, 0.7);
  border: 1rpx solid rgba(120, 165, 255, 0.22);
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #eaf0ff;
}

.textarea {
  width: 100%;
  box-sizing: border-box;
  background: rgba(8, 14, 30, 0.7);
  border: 1rpx solid rgba(120, 165, 255, 0.22);
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #eaf0ff;
  height: 140rpx;
}

.input-placeholder,
.textarea-placeholder {
  color: #5e6a92;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(56, 120, 255, 0.08);
  color: #aebbe6;
  font-size: 26rpx;
  border: 1rpx solid rgba(120, 165, 255, 0.2);
}

.chip-on {
  background: linear-gradient(135deg, rgba(34, 211, 238, 0.22), rgba(139, 92, 255, 0.22));
  color: #eaf6ff;
  border-color: rgba(95, 230, 255, 0.7);
  box-shadow: 0 0 18rpx rgba(72, 160, 255, 0.4);
}

.label .muted,
.card .muted {
  margin-top: 10rpx;
}

.submit-btn {
  margin-top: 32rpx;
  width: 100%;
}

.submit-btn::after {
  border: none;
}
