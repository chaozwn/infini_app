/* 整屏纵向布局：标题/状态卡/按钮固定，报告卡占满剩余高度并内部滚动 */
.result-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.result-page .page-title,
.result-page .status-card,
.result-page .paused-card,
.result-page .done-card,
.result-page .actions {
  flex-shrink: 0;
}

.page-title {
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

/* ===== 运行中状态卡 ===== */
.status-card {
  position: relative;
  border-color: rgba(95, 230, 255, 0.35);
  background: linear-gradient(180deg, rgba(16, 40, 62, 0.9), rgba(13, 22, 44, 0.92));
}

/* 顶部扫描线 */
.scanner {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 100%;
  overflow: hidden;
  pointer-events: none;
}

.scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(34, 211, 238, 0.18), transparent);
  animation: scanY 2.6s ease-in-out infinite;
}

@keyframes scanY {
  0% { top: -120rpx; }
  100% { top: 100%; }
}

.status-row {
  position: relative;
  display: flex;
  align-items: center;
}

.ring {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(95, 230, 255, 0.2);
  border-top-color: #5fe6ff;
  border-right-color: #8b5cff;
  margin-right: 18rpx;
  animation: spin 0.8s linear infinite;
  box-shadow: 0 0 18rpx rgba(72, 160, 255, 0.5);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.status-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #eaf2ff;
}

.work-steps {
  position: relative;
  margin-top: 22rpx;
  display: flex;
  gap: 14rpx;
}

.work-step {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  color: #b9c5ee;
  background: rgba(56, 120, 255, 0.1);
  border: 1rpx solid rgba(120, 165, 255, 0.2);
  animation: stepPulse 2.4s ease-in-out infinite;
}

.work-step:nth-child(2) { animation-delay: 0.4s; }
.work-step:nth-child(3) { animation-delay: 0.8s; }

@keyframes stepPulse {
  0%, 100% { border-color: rgba(120, 165, 255, 0.2); box-shadow: none; }
  50% { border-color: rgba(95, 230, 255, 0.6); box-shadow: 0 0 18rpx rgba(72, 160, 255, 0.35); }
}

.ws-icon {
  margin-right: 8rpx;
}

.status-card .muted {
  position: relative;
  margin-top: 16rpx;
}

/* ===== 暂停卡 ===== */
.paused-card {
  border-color: rgba(255, 206, 106, 0.4);
  background: linear-gradient(180deg, rgba(58, 44, 18, 0.7), rgba(28, 22, 14, 0.8));
}

.paused-row {
  display: flex;
  align-items: center;
}

.paused-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 206, 106, 0.18);
  border: 1rpx solid rgba(255, 206, 106, 0.45);
  color: #ffce6a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.paused-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffdf9e;
  line-height: 1.5;
}

.paused-card .muted {
  margin-top: 14rpx;
}

.paused-btn {
  margin-top: 24rpx;
}

/* ===== 完成卡 ===== */
.done-card {
  border-color: rgba(52, 226, 176, 0.4);
  background: linear-gradient(180deg, rgba(14, 48, 40, 0.7), rgba(12, 26, 34, 0.85));
}

.done-card .muted {
  margin-top: 14rpx;
}

/* ===== 报告卡（终端风）：占满剩余高度内部滚动 ===== */
.progress-card {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.progress-head-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f1f4ff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.live-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #5fe6ff;
  margin-right: 14rpx;
  box-shadow: 0 0 0 0 rgba(95, 230, 255, 0.5);
  animation: pulse 1.4s ease-out infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(95, 230, 255, 0.5); }
  70% { box-shadow: 0 0 0 14rpx rgba(95, 230, 255, 0); }
  100% { box-shadow: 0 0 0 0 rgba(95, 230, 255, 0); }
}

.progress-tag {
  flex-shrink: 0;
  margin-left: 16rpx;
  margin-right: 2rpx;
  font-size: 22rpx;
  color: #5fe6ff;
  background: rgba(34, 211, 238, 0.12);
  border: 1rpx solid rgba(95, 230, 255, 0.4);
  border-radius: 999rpx;
  padding: 4rpx 18rpx;
}

/* 工具调用截图条 */
.shots-wrap {
  flex-shrink: 0;
  margin-bottom: 18rpx;
}

.shots-label {
  font-size: 22rpx;
  color: #5fe6ff;
  margin-bottom: 12rpx;
}

.shots {
  width: 100%;
  white-space: nowrap;
}

.shot {
  display: inline-flex;
  width: 280rpx;
  height: 190rpx;
  margin-right: 14rpx;
  border-radius: 14rpx;
  overflow: hidden;
  border: 1rpx solid rgba(95, 230, 255, 0.3);
  background: rgba(6, 11, 24, 0.6);
  box-shadow: 0 0 16rpx rgba(34, 120, 255, 0.18);
  vertical-align: top;
}

.shot:last-child {
  margin-right: 0;
}

.shot-img {
  width: 100%;
  height: 100%;
  display: block;
}

.report {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  background: rgba(6, 11, 24, 0.85);
  border: 1rpx solid rgba(95, 230, 255, 0.22);
  border-radius: 18rpx;
  padding: 26rpx 24rpx;
  box-shadow: inset 0 0 40rpx rgba(34, 120, 255, 0.08);
}

.report-text {
  font-size: 26rpx;
  line-height: 1.85;
  color: #c8d4f5;
  word-break: break-word;
  white-space: pre-wrap;
}
