.page-title {
  margin-top: 8rpx;
}

.subtitle {
  margin: 12rpx 0 24rpx;
}

.warn-card {
  border-color: #f3d9a0;
  background: #fffaf0;
}

.step-title {
  font-size: 30rpx;
  font-weight: 700;
}

.card .muted {
  margin-top: 10rpx;
}

.link-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  background: #f8f2ec;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
}

.link-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #5b4f47;
  word-break: break-all;
  margin-right: 16rpx;
}

.btn-copy {
  flex-shrink: 0;
  margin: 0;
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  background: #e6442e;
  border-radius: 12rpx;
}

.btn-copy::after {
  border: none;
}

.steps {
  margin-top: 16rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}

.step-item + .step-item {
  border-top: 1rpx solid #f5ece6;
}

.step-no {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: #0a0a0a;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  line-height: 44rpx;
  margin-right: 18rpx;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.detect-card {
  border-color: #f3c6bc;
  background: #fff6f3;
}

.detect-btn {
  margin-top: 24rpx;
  width: 100%;
}

.detect-btn::after {
  border: none;
}
