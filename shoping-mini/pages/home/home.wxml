<view class="page">
  <view class="hero">
    <view class="hero-badge">🛍️</view>
    <view class="hero-text">
      <view class="hero-title neon-text">省钱比价助手</view>
      <view class="hero-sub">AI · 跨平台比价 · 读差评 · 自动加购物车</view>
    </view>
  </view>

  <view class="card link-card">
    <view class="link-head">
      <text class="link-head-title">远程购物链路</text>
      <view class="link-status {{pluginConnected ? 'on' : (pluginChecking ? 'checking' : 'off')}}">
        <view class="dot"></view>
        <text>{{pluginConnected ? '已就绪' : (pluginChecking ? '检测中…' : '未连接')}}</text>
      </view>
    </view>
    <view class="link-diagram">
      <view class="node">
        <view class="node-icon">📱</view>
        <text class="node-label">手机</text>
      </view>
      <view class="link-line {{pluginConnected ? 'active' : ''}}">
        <view class="pulse"></view>
        <view class="pulse p2"></view>
        <view class="pulse p3"></view>
      </view>
      <view class="node">
        <view class="node-icon">🖥️</view>
        <text class="node-label">PC 插件</text>
      </view>
    </view>
    <view class="link-tip muted">手机下单需求，PC 端 Chrome 插件远程执行比价与自动加购</view>
  </view>

  <view class="card account-card">
    <view class="account-row">
      <view class="avatar">🛒</view>
      <view class="account-info">
        <view class="account-phone">{{account.phone || '未获取手机号'}}</view>
        <view wx:if="{{bound}}" class="tag tag-emerald">已关联 InfiniSynapse 账号</view>
        <view wx:elif="{{needBindPhone}}" class="tag tag-amber">未授权手机号</view>
        <view wx:else class="tag tag-amber">手机号未匹配到账号</view>
      </view>
    </view>

    <view wx:if="{{needBindPhone}}" class="account-tip">
      <view class="muted">还没授权手机号，无法关联账号。</view>
      <button class="btn btn-primary tip-btn" bindtap="bindPhone">去授权手机号</button>
    </view>
    <view wx:elif="{{!bound}}" class="account-tip">
      <view class="muted">该手机号还没有 InfiniSynapse 账号，请在 PC 端用同一手机号注册/绑定。</view>
    </view>
  </view>

  <view class="card action-card">
    <view class="step-title">开始 AI 购物</view>
    <view class="muted">在 PC 端 Chrome 装好插件、用同一账号登录后，点下方「检测插件」即可开始比价。</view>

    <view class="feature-row">
      <view class="feature-pill"><text class="fp-icon">🔍</text>AI 比价</view>
      <view class="feature-pill"><text class="fp-icon">🛡️</text>读差评</view>
      <view class="feature-pill"><text class="fp-icon">🛒</text>自动加购</view>
    </view>

    <view class="action-list">
      <block wx:if="{{bound}}">
        <button class="btn btn-primary action-btn" bindtap="detectPlugin" loading="{{detecting}}">
          检测插件并开始比价
        </button>
        <button class="btn btn-ghost action-btn" bindtap="goGuide">
          <text class="btn-emoji">🖥️</text>查看 PC 安装指引
        </button>
      </block>
      <block wx:else>
        <button class="btn btn-dark action-btn" bindtap="goGuide">
          <text class="btn-emoji">🖥️</text>去 PC 安装插件并开始
        </button>
      </block>
      <button class="btn btn-ghost action-btn" bindtap="goTasks">
        <text class="btn-emoji">🧾</text>历史任务
      </button>
    </view>
  </view>

  <view class="logout-wrap">
    <text class="logout-link" bindtap="logout">退出登录</text>
  </view>
</view>
