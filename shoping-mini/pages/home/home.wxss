.account-card {
  margin-top: 8rpx;
}

.account-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #fff1eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.account-info {
  flex: 1;
  min-width: 0;
}

.account-phone {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.account-tip {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f5ece6;
}

.tip-btn {
  margin-top: 20rpx;
}

.step-title {
  font-size: 32rpx;
  font-weight: 700;
}

.card .muted {
  margin-top: 12rpx;
}

.action-btn {
  margin-top: 24rpx;
}

.logout-btn {
  margin-top: 32rpx;
}
