<view class="page">
  <view class="title page-title">购物任务</view>

  <block wx:if="{{tasks.length > 0}}">
    <view class="card task-item" wx:for="{{tasks}}" wx:key="taskId">
      <view class="task-title">{{item.title || item.item || '购物任务'}}</view>
      <view class="muted">{{item.status || ''}}</view>
    </view>
  </block>

  <block wx:else>
    <view class="card empty-card">
      <view class="empty-emoji">🖥️</view>
      <view class="empty-text">{{message || '暂无购物任务'}}</view>
      <button class="btn btn-dark empty-btn" bindtap="goGuide">去 PC 安装插件并开始</button>
    </view>
  </block>
</view>
