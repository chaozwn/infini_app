.hero {
  padding: 48rpx 8rpx 24rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(34, 211, 238, 0.1);
  border: 1rpx solid rgba(95, 230, 255, 0.4);
  color: #5fe6ff;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 0 18rpx rgba(72, 160, 255, 0.25);
}

.hero .title {
  margin-top: 24rpx;
  font-size: 58rpx;
  line-height: 1.2;
  background: linear-gradient(135deg, #5fe6ff 0%, #9b8cff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.hero .subtitle {
  margin-top: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #c5cef0;
}

.feature-item + .feature-item {
  border-top: 1rpx solid rgba(120, 165, 255, 0.12);
}

.feature-emoji {
  margin-right: 16rpx;
  font-size: 34rpx;
}

.login-card {
  margin-top: 24rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f1f4ff;
}

.login-card .muted {
  margin-top: 12rpx;
}

.login-btn {
  margin-top: 28rpx;
}

.footer {
  margin-top: 40rpx;
  text-align: center;
}
