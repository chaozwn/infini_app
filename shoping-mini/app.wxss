/**app.wxss — 深色科技主题**/
page {
  background-color: #060a16;
  background-image:
    radial-gradient(1200rpx 760rpx at 12% -6%, rgba(56, 189, 248, 0.18), transparent 60%),
    radial-gradient(1000rpx 720rpx at 112% 6%, rgba(124, 92, 255, 0.20), transparent 55%),
    radial-gradient(900rpx 900rpx at 50% 120%, rgba(34, 211, 238, 0.10), transparent 60%),
    linear-gradient(rgba(120, 160, 255, 0.045) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(120, 160, 255, 0.045) 1rpx, transparent 1rpx);
  background-size: auto, auto, auto, 40rpx 40rpx, 40rpx 40rpx;
  color: #e7ecff;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

/* 通用玻璃卡片 */
.card {
  position: relative;
  background: linear-gradient(180deg, rgba(24, 33, 60, 0.82) 0%, rgba(14, 20, 38, 0.86) 100%);
  border: 1rpx solid rgba(120, 165, 255, 0.16);
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  box-shadow: 0 16rpx 44rpx rgba(0, 0, 0, 0.38), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

/* 卡片顶部一条霓虹高光线 */
.card::before {
  content: "";
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(34, 211, 238, 0.55), rgba(124, 92, 255, 0.55), transparent);
  opacity: 0.8;
}

.card + .card {
  margin-top: 24rpx;
}

/* 通用按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}

.btn::after {
  border: none;
}

/* 主操作：青→紫 霓虹渐变 + 辉光 */
.btn-primary {
  background: linear-gradient(135deg, #22d3ee 0%, #5b8cff 50%, #8b5cff 100%);
  color: #04122a;
  font-weight: 700;
  box-shadow: 0 10rpx 30rpx rgba(72, 130, 255, 0.45), 0 0 1rpx rgba(255, 255, 255, 0.4) inset;
}

.btn-primary[disabled] {
  background: linear-gradient(135deg, #2a5566, #2f3d6e);
  color: rgba(255, 255, 255, 0.6);
  box-shadow: none;
}

/* 深色科技面板按钮 */
.btn-dark {
  background: rgba(18, 26, 50, 0.9);
  color: #d7e3ff;
  border: 1rpx solid rgba(120, 165, 255, 0.35);
  box-shadow: inset 0 0 24rpx rgba(56, 120, 255, 0.12);
}

/* 幽灵按钮 */
.btn-ghost {
  background: rgba(255, 255, 255, 0.02);
  color: #aebbe6;
  border: 1rpx solid rgba(120, 165, 255, 0.22);
}

.btn + .btn {
  margin-top: 20rpx;
}

.muted {
  color: #8b97c0;
  font-size: 24rpx;
  line-height: 1.6;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #f1f4ff;
  letter-spacing: 1rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8b97c0;
  line-height: 1.6;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-emerald {
  background: rgba(16, 185, 129, 0.14);
  color: #34e2b0;
  border: 1rpx solid rgba(52, 226, 176, 0.4);
}

.tag-amber {
  background: rgba(245, 158, 11, 0.14);
  color: #ffce6a;
  border: 1rpx solid rgba(255, 206, 106, 0.4);
}

.tag-cyan {
  background: rgba(34, 211, 238, 0.14);
  color: #5fe6ff;
  border: 1rpx solid rgba(95, 230, 255, 0.4);
}

/* 通用：青紫渐变文字（用于强调标题） */
.neon-text {
  background: linear-gradient(135deg, #5fe6ff 0%, #9b8cff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
