# ─────────────────────────────────────────────────────────────
# InfiniSynapse Web Demo · 环境变量示例
# 复制为 .env.local 后按需修改。切勿把真实密钥提交到 Git。
# ─────────────────────────────────────────────────────────────

# true = 内存 Mock Agent（默认，零密钥可跑通全链路）
# false = 调用真实 InfiniSynapse Agent（需配置下方 API Key）
MOCK_AGENT=true

# Demo 会话签名密钥（生产务必换成长随机串；Mock 模式下可用默认值）
DEMO_JWT_SECRET=dev-only-change-me-before-production

# ── 仅 MOCK_AGENT=false 时需要 ──
# 在 https://app.infinisynapse.cn （或你的私有部署）创建 API Key
INFINISYNAPSE_API_KEY=sk-your-api-key-here
# Agent 服务地址（不要把密钥写进前端）
INFINISYNAPSE_SERVER=https://app.infinisynapse.cn
# 可选：Agent 语言
INFINISYNAPSE_LANG=zh_CN
